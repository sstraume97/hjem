{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/document/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:LM Roman 8|LM Roman 9|LM Roman 10|LM Roman 12|LM Roman 17|LM Roman Demi 10|LM Roman Caps 10|Playfair Display|Libre Baskerville))/i]",
        "message": "Font not provided by the design system. Available: LM Roman 8, LM Roman 9, LM Roman 10, LM Roman 12, LM Roman 17, LM Roman Demi 10, LM Roman Caps 10, Playfair Display, Libre Baskerville."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: kind, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:info|warning)$/]",
        "message": "<Callout> kind must be one of 'info' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColoredBulletList'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|key|ref|className|style|children)$/]",
        "message": "<ColoredBulletList> doesn't accept that prop. Declared props: items."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:weight|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: weight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='weight'] > Literal[value!=/^(?:thin|thick)$/]",
        "message": "<Divider> weight must be one of 'thin' | 'thick'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmailSignature'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|address|phone|email|web|key|ref|className|style|children)$/]",
        "message": "<EmailSignature> doesn't accept that prop. Declared props: name, address, phone, email, web."
      },
      {
        "selector": "JSXOpeningElement[name.name='Heading'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|children|key|ref|className|style|children)$/]",
        "message": "<Heading> doesn't accept that prop. Declared props: level, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Quote'] > JSXAttribute > JSXIdentifier[name!=/^(?:strong|cite|children|key|ref|className|style|children)$/]",
        "message": "<Quote> doesn't accept that prop. Declared props: strong, cite, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Signature'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|title|key|ref|className|style|children)$/]",
        "message": "<Signature> doesn't accept that prop. Declared props: name, title."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
